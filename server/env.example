# Server Configuration
PORT=4000
NODE_ENV=development

# MongoDB Configuration
# Preferred for cloud startup
MONGODB_ATLAS_URI=mongodb+srv://username:password@cluster.mongodb.net/nature_app?retryWrites=true&w=majority

# Optional local fallback for development
# MONGODB_LOCAL_URI=mongodb://127.0.0.1:27017/nature_app

# JWT Configuration (for future auth)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=7d

# Default admin bootstrap (recreated automatically if missing)
ADMIN_EMAIL=admin@natureapp.local
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=System Admin

# Optional: MongoDB Atlas Connection String Format
# mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
